# =============================================================================
# Local Development Environment Variables
#
# Copy this file to .env in your project root:
#   cp .env.example .env
#
# These values match the docker-compose.dev.yaml defaults.
# NEVER commit .env to source control.
# =============================================================================

# PostgreSQL (matches docker-compose.dev.yaml)
DATABASE_URL=postgresql://appuser:localdevpassword@localhost:5433/appdb

# Azure Storage (Azurite local emulator)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10100/devstoreaccount1;QueueEndpoint=http://127.0.0.1:10101/devstoreaccount1;TableEndpoint=http://127.0.0.1:10102/devstoreaccount1

# Application
PORT=3001
NODE_ENV=development

# Entra ID (Azure AD) — replace with your app registration values
AZURE_AD_TENANT_ID=your-tenant-id-here
AZURE_AD_CLIENT_ID=your-client-id-here

# Local dev convenience — not used in production
JWT_SECRET=local-dev-jwt-secret-replace-in-production
